# =============================================================================
# Lab Invoice Manager — Environment Variables
# Copy this file to .env.local for development. Never commit .env.local.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Local: matches infra/docker-compose.yml
DATABASE_URL="postgresql://lim:lim_dev_password@localhost:5432/lim_dev?schema=public"

# --- Session / cookies --------------------------------------------------------
# Generate a strong 32+ char random string. Used to encrypt session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="CHANGE_ME_dev_only_32_byte_random_hex_string_required_xxxxxxxxxxxx"

# --- Encryption (patient name column-level encryption) ------------------------
# In dev we use a static key; in production this is replaced by AWS KMS.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY_DEV="CHANGE_ME_base64_encoded_32_byte_key_for_dev_only_xxxxxxxxxxxxxx="

# HMAC key for searchable hash of patient names (separate from encryption key)
PATIENT_SEARCH_HMAC_KEY="CHANGE_ME_base64_encoded_32_byte_key_for_dev_only_xxxxxxxxxxxxxx="

# --- S3 / object storage (MinIO locally, AWS S3 in production) ----------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="eu-west-2"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="dsd-lim-dev"
S3_FORCE_PATH_STYLE="true"

# --- AI extraction (Anthropic Claude — fallback for unknown lab formats) -----
# Sign up at https://console.anthropic.com, generate an API key.
# Never commit a real key. .env.local is in .gitignore; this .env.example file
# stays in git but contains only a placeholder.
ANTHROPIC_API_KEY="sk-ant-api03-CHANGE_ME"

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="DSD Lab Invoice Manager"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Feature flags
ENABLE_MFA_ENFORCEMENT="false" # set to "true" before any real data is loaded
